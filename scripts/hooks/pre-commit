#!/usr/bin/env bash
# Pre-commit hook: compile scripts + sync to ChromaScape
# Blocks commit if compilation fails.
# Skip with: git commit --no-verify

set -euo pipefail

echo "pre-commit: running osrs-bot build..."

if command -v osrs-bot &>/dev/null; then
  osrs-bot build
  osrs-bot lint || true
else
  # Fallback if CLI not installed
  ./scripts/sync-and-compile.sh
fi
